#!/usr/bin/env bash
# Rebuild the lolterm-kali image and recreate the Kali container.
# Uses the local config at ~/.local/share/lolterm/kali-container/

set -euo pipefail

CONFIG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/lolterm/kali-container"

if [[ ! -d "$CONFIG_DIR" ]]; then
  echo "Kali container config not found at $CONFIG_DIR" >&2
  echo "Run lolterm installer with --kali-container first." >&2
  exit 1
fi

echo "==> Rebuilding lolterm-kali image..."
podman build -t lolterm-kali "$CONFIG_DIR"

echo "==> Removing old kali container..."
podman rm -f kali 2>/dev/null || true

echo "==> Creating new kali container..."

# Detect SELinux enforcing mode for volume flags
vol_flag=""
if command -v getenforce &>/dev/null && [[ "$(getenforce)" == "Enforcing" ]]; then
  vol_flag=":Z"
fi

podman create --name kali \
  --network host \
  --privileged \
  -v /tmp/.X11-unix:/tmp/.X11-unix"${vol_flag}" \
  -v "$HOME:$HOME${vol_flag}" \
  -e DISPLAY \
  lolterm-kali \
  sleep infinity

echo "==> Regenerating systemd user service..."
service_dir="${XDG_DATA_HOME:-$HOME/.local/share}/lolterm/kali-container"
mkdir -p "$HOME/.config/systemd/user"
podman generate systemd --name kali --new > "$HOME/.config/systemd/user/container-kali.service"
systemctl --user daemon-reload
systemctl --user enable --now container-kali.service

echo "==> Regenerating tool wrappers..."
bindir="$HOME/.local/bin"
mkdir -p "$bindir"

# Normal wrappers
while IFS= read -r line; do
  line="${line## }"
  line="${line%% }"
  [[ -z "$line" || "$line" =~ ^# ]] && continue
  cat > "$bindir/$line" <<'WRAPPER'
#!/usr/bin/env bash
# Kali container wrapper — generated by lolterm
exec podman exec -it -w "$PWD" kali "$(basename "$0")" "$@"
WRAPPER
  chmod +x "$bindir/$line"
done < "$CONFIG_DIR/tools.txt"

# Privileged wrappers
while IFS= read -r line; do
  line="${line## }"
  line="${line%% }"
  [[ -z "$line" || "$line" =~ ^# ]] && continue
  cat > "$bindir/$line" <<'WRAPPER'
#!/usr/bin/env bash
# Kali container wrapper — generated by lolterm
exec podman exec --privileged -it -w "$PWD" kali "$(basename "$0")" "$@"
WRAPPER
  chmod +x "$bindir/$line"
done < "$CONFIG_DIR/tools-privileged.txt"

echo ""
echo "Done. Kali container rebuilt and tools wrappers regenerated."
echo "Run 'kali-sh' to open an interactive Kali shell."
