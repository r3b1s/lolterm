#!/usr/bin/env bash
# Rebuild the lolterm-kali image and recreate the Kali container.
# Uses the local config at ~/.local/share/lolterm/kali-container/
# Adapts to the container runtime (Docker or Podman) detected at install time.

set -euo pipefail

CONFIG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/lolterm/kali-container"

if [[ ! -d "$CONFIG_DIR" ]]; then
  echo "Kali container config not found at $CONFIG_DIR" >&2
  echo "Run lolterm installer with --kali-container first." >&2
  exit 1
fi

# Detect runtime from state file
RUNTIME_FILE="$CONFIG_DIR/runtime.txt"
KALI_RUNTIME="podman"
if [[ -f "$RUNTIME_FILE" ]]; then
  KALI_RUNTIME="$(<"$RUNTIME_FILE")"
fi

echo "==> Rebuilding lolterm-kali image with runtime: $KALI_RUNTIME..."

if [[ "$KALI_RUNTIME" == "docker" ]]; then
  CMD="docker"
  COMPOSE_DIR="$HOME/.config/containers/systemd"
  COMPOSE_FILE="$COMPOSE_DIR/compose.yaml"
else
  CMD="podman"
fi

$CMD build -t lolterm-kali "$CONFIG_DIR"

echo "==> Restarting container..."

if [[ "$KALI_RUNTIME" == "docker" ]]; then
  if [[ -f "$COMPOSE_FILE" ]]; then
    (cd "$COMPOSE_DIR" && docker compose up -d)
    echo "  Docker Compose service restarted with new image"
  else
    echo "  Compose file not found; setting up..."
    if [[ -f "$CONFIG_DIR/compose.yaml" ]]; then
      mkdir -p "$COMPOSE_DIR"
      cp -f "$CONFIG_DIR/compose.yaml" "$COMPOSE_FILE"
      (cd "$COMPOSE_DIR" && docker compose up -d)
      echo "  Compose installed and service started"
    else
      echo "  Warning: compose.yaml not found — starting container manually" >&2
      docker rm -f kali 2>/dev/null || true
      docker run -d --name kali --network host \
        -v /tmp/.X11-unix:/tmp/.X11-unix \
        -v "$HOME:/root:rw" \
        localhost/lolterm-kali sleep infinity
    fi
  fi
else
  # Podman quadlet path
  if systemctl --user list-units --all --no-legend kali.service 2>/dev/null | grep -q .; then
    systemctl --user restart kali.service
    echo "  Quadlet service restarted with new image"
  else
    echo "  Quadlet not yet installed; setting up..."
    QUADLET_DIR="$HOME/.config/containers/systemd"
    mkdir -p "$QUADLET_DIR"
    cp -f "$CONFIG_DIR/kali.container" "$QUADLET_DIR/kali.container"
    rm -f "$HOME/.config/systemd/user/container-kali.service"
    loginctl enable-linger "$(whoami)" 2>/dev/null || true
    systemctl --user daemon-reload
    systemctl --user start kali.service
    echo "  Quadlet installed and service started"
  fi
fi

echo "==> Regenerating tool wrappers..."
bindir="$HOME/.local/bin"
mkdir -p "$bindir"

generate_wrapper() {
  local tool="$1"
  local extra_args="${2:-}"

  if [[ "$KALI_RUNTIME" == "docker" ]]; then
    cat > "$bindir/$tool" <<WRAPPER
#!/usr/bin/env bash
# Kali container wrapper — generated by lolterm

# Auto-start container if it exists but isn't running
if ! docker container inspect kali &>/dev/null 2>&1; then
  echo "Kali container not found. Run: lolterm-kali-rebuild" >&2
  exit 1
fi
if [[ "\$(docker inspect --format '{{.State.Status}}' kali 2>/dev/null)" != "running" ]]; then
  docker start kali >/dev/null
fi

exec docker exec ${extra_args} -it -w "\$PWD" -e DISPLAY -e XAUTHORITY kali "\$(basename "\$0")" "\$@"
WRAPPER
  else
    cat > "$bindir/$tool" <<WRAPPER
#!/usr/bin/env bash
# Kali container wrapper — generated by lolterm

# Auto-start container if it exists but isn't running
if ! podman container exists kali 2>/dev/null; then
  echo "Kali container not found. Run: lolterm-kali-rebuild" >&2
  exit 1
fi
if [[ "\$(podman inspect --format '{{.State.Status}}' kali 2>/dev/null)" != "running" ]]; then
  podman start kali >/dev/null
fi

exec podman exec ${extra_args} -it -w "\$PWD" -e DISPLAY -e XAUTHORITY kali "\$(basename "\$0")" "\$@"
WRAPPER
  fi
  chmod +x "$bindir/$tool"
}

# Normal wrappers
while IFS= read -r line; do
  line="${line## }"
  line="${line%% }"
  [[ -z "$line" || "$line" =~ ^# ]] && continue
  generate_wrapper "$line" ""
done < "$CONFIG_DIR/tools.txt"

# Privileged wrappers
while IFS= read -r line; do
  line="${line## }"
  line="${line%% }"
  [[ -z "$line" || "$line" =~ ^# ]] && continue
  generate_wrapper "$line" "--privileged"
done < "$CONFIG_DIR/tools-privileged.txt"

echo ""
echo "==> Extracting Kali logo icon..."
icon_dir="$HOME/.local/share/icons/hicolor/scalable/apps"
mkdir -p "$icon_dir"
icon_path="$($CMD run --rm lolterm-kali sh -c '
  find /usr/share/icons /usr/share/pixmaps -name "kali*" -path "*/scalable/*" 2>/dev/null | head -1
' 2>/dev/null)" || true
if [[ -n "$icon_path" ]]; then
  local cid
  cid="$($CMD create lolterm-kali 2>/dev/null)"
  if [[ -n "$cid" ]]; then
    $CMD cp "$cid:$icon_path" "$icon_dir/kali-logo.svg" 2>/dev/null && \
      echo "  Icon extracted to $icon_dir/kali-logo.svg"
    $CMD rm "$cid" >/dev/null 2>&1 || true
  fi
else
  icon_path="$($CMD run --rm lolterm-kali sh -c '
    find /usr/share/icons /usr/share/pixmaps -name "kali*" 2>/dev/null | head -1
  ' 2>/dev/null)" || true
  if [[ -n "$icon_path" ]]; then
    local cid
    cid="$($CMD create lolterm-kali 2>/dev/null)"
    if [[ -n "$cid" ]]; then
      ext="${icon_path##*.}"
      $CMD cp "$cid:$icon_path" "$icon_dir/kali-logo.$ext" 2>/dev/null && \
        echo "  Icon extracted to $icon_dir/kali-logo.$ext"
      $CMD rm "$cid" >/dev/null 2>&1 || true
    fi
  else
    echo "  Warning: Kali logo icon not found — desktop entries will use placeholder"
  fi
fi

echo "==> Generating .desktop entries for GUI tools..."
desktop_dir="$HOME/.local/share/applications"
mkdir -p "$desktop_dir"
if [[ -f "$CONFIG_DIR/tools-gui.txt" ]]; then
  while IFS= read -r line; do
    line="${line## }"
    line="${line%% }"
    [[ -z "$line" || "$line" =~ ^# ]] && continue
    first="${line:0:1}"
    rest="${line:1}"
    display_name="$(tr '[:lower:]' '[:upper:]' <<<"$first")$rest"
    cat > "$desktop_dir/kali-$line.desktop" <<DESKTOP
[Desktop Entry]
Version=1.0
Type=Application
Name=$display_name (Kali)
Comment=Kali container tool
Exec=$HOME/.local/bin/$line %F
Icon=kali-logo
Terminal=false
Categories=Security;
DESKTOP
  done < "$CONFIG_DIR/tools-gui.txt"
  echo "  Desktop entries generated in $desktop_dir"
else
  echo "  tools-gui.txt not found — skipping desktop entries"
fi

echo ""
echo "Done. Kali container rebuilt, tools wrappers, icons, and desktop entries regenerated."
echo "Run 'kali-sh' to open an interactive Kali shell."
