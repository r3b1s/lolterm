#!/usr/bin/env bash
set -euo pipefail

# Interactive setup for lolterm
# Run this after a headless install, or it runs automatically during normal install.

section() {
  echo ""
  gum style --bold --foreground 4 "==> $1"
}

warn_vpn_access() {
  local vpn="$1"
  gum style --bold --foreground 3 "Access control warning"
  echo "$vpn authentication can grant this endpoint broad peer access if your VPN ACLs, groups, tags, or setup-key policies are not restricted."
  echo "Use a scoped setup/auth key for servers whenever possible."
  echo ""
}

install_netbird() {
  if ! command -v netbird &>/dev/null; then
    echo "Installing NetBird..."
    local key_url key_file
    key_url="https://pkgs.netbird.io/yum/repodata/repomd.xml.key"
    key_file="$(mktemp)"
    curl -fsSLo "$key_file" "$key_url"
    sudo rpm --import "$key_file"
    rm -f "$key_file"

    sudo tee /etc/yum.repos.d/netbird.repo <<'REPO' >/dev/null
[netbird]
name=netbird
baseurl=https://pkgs.netbird.io/yum/
enabled=1
gpgcheck=1
gpgkey=https://pkgs.netbird.io/yum/repodata/repomd.xml.key
repo_gpgcheck=1
REPO
    sudo dnf install -y netbird
  fi
}

netbird_up() {
  local setup_key="${1:-}"
  local -a args=(
    --enable-rosenpass
    --rosenpass-permissive
    --wireguard-port 51821
    --allow-server-ssh
    --enable-ssh-local-port-forwarding
    --enable-ssh-remote-port-forwarding
    --enable-ssh-root
    --enable-ssh-sftp
  )

  if [[ -n "$setup_key" ]]; then
    args=(--setup-key "$setup_key" "${args[@]}")
  else
    args=(--no-browser "${args[@]}")
  fi

  netbird up "${args[@]}"
}

setup_netbird() {
  install_netbird
  warn_vpn_access "NetBird"

  local auth_choice setup_key
  auth_choice=$(gum choose --header "Authenticate NetBird" "Browser link" "Setup key" "Manual later" </dev/tty)

  case "$auth_choice" in
    "Browser link")
      netbird_up ""
      ;;
    "Setup key")
      setup_key=$(gum input --password --placeholder "NetBird setup key" --prompt "Setup key: " </dev/tty)
      if [[ -n "$setup_key" ]]; then
        netbird_up "$setup_key"
      else
        echo "No setup key provided. Skipping NetBird authentication."
      fi
      ;;
    "Manual later")
      echo "Skipping NetBird authentication. Run 'netbird up' later."
      ;;
  esac
}

setup_tailscale() {
  echo "Installing Tailscale..."
  sudo dnf install -y tailscale
  sudo systemctl enable --now tailscaled.service
  warn_vpn_access "Tailscale"

  local auth_choice auth_key
  auth_choice=$(gum choose --header "Authenticate Tailscale" "Browser link" "Auth key" "Manual later" </dev/tty)

  case "$auth_choice" in
    "Browser link")
      sudo tailscale up --ssh --accept-routes
      ;;
    "Auth key")
      auth_key=$(gum input --password --placeholder "Tailscale auth key" --prompt "Auth key: " </dev/tty)
      if [[ -n "$auth_key" ]]; then
        sudo tailscale up --ssh --accept-routes --auth-key "$auth_key"
      else
        echo "No auth key provided. Skipping Tailscale authentication."
      fi
      ;;
    "Manual later")
      echo "Skipping Tailscale authentication. Run 'sudo tailscale up' later."
      ;;
  esac
}

# ---------- Git configuration ----------
section "Git Configuration"

if ! git config --global user.name &>/dev/null; then
  GIT_NAME=$(gum input --placeholder "Your Name" --prompt "Git name: " </dev/tty)
  if [[ -n "$GIT_NAME" ]]; then
    git config --global user.name "$GIT_NAME"
  fi
fi

if ! git config --global user.email &>/dev/null; then
  GIT_EMAIL=$(gum input --placeholder "you@example.com" --prompt "Git email: " </dev/tty)
  if [[ -n "$GIT_EMAIL" ]]; then
    git config --global user.email "$GIT_EMAIL"
  fi
fi

git config --global init.defaultBranch main
echo "Git configured as: $(git config --global user.name) <$(git config --global user.email)>"

# ---------- GitHub authentication ----------
section "GitHub"

if ! gh auth status &>/dev/null; then
  if gum confirm "Authenticate with GitHub?" </dev/tty; then
    gh auth login </dev/tty
  fi
fi

# ---------- VPN ----------
tailscale_needs_setup=false
netbird_needs_setup=false

if ! command -v tailscale &>/dev/null || ! tailscale status &>/dev/null 2>&1; then
  tailscale_needs_setup=true
fi

if ! command -v netbird &>/dev/null || ! netbird status 2>/dev/null | grep -q "Connected"; then
  netbird_needs_setup=true
fi

if $tailscale_needs_setup && $netbird_needs_setup; then
  section "VPN"
  VPN_CHOICE=$(gum choose --header "Install VPN?" "Tailscale" "NetBird" "Both" "Skip" </dev/tty)

  case "$VPN_CHOICE" in
    Tailscale)
      setup_tailscale
      ;;
    NetBird)
      setup_netbird
      ;;
    Both)
      setup_tailscale
      setup_netbird
      ;;
    Skip)
      echo "Skipping VPN setup."
      ;;
  esac
elif $tailscale_needs_setup; then
  section "Tailscale"
  if gum confirm "Set up Tailscale?" </dev/tty; then
    setup_tailscale
  fi
elif $netbird_needs_setup; then
  section "NetBird"
  if gum confirm "Set up NetBird?" </dev/tty; then
    setup_netbird
  fi
fi

# ---------- SSH key (if not already set up) ----------
section "SSH Access"

if [ ! -f "$HOME/.ssh/authorized_keys" ] || [ ! -s "$HOME/.ssh/authorized_keys" ]; then
  if gum confirm "Add an SSH public key for remote access?" </dev/tty; then
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"

    SSH_KEY=$(gum input --placeholder "ssh-ed25519 AAAAC3..." --prompt "SSH key: " </dev/tty)

    if [[ -n "$SSH_KEY" ]]; then
      echo "$SSH_KEY" >> "$HOME/.ssh/authorized_keys"
      chmod 600 "$HOME/.ssh/authorized_keys"
      echo "SSH key added."

      if gum confirm "Disable password authentication (key-only SSH)?" </dev/tty; then
        sudo sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config
        sudo sed -i 's/^#*PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config
        sudo systemctl restart sshd.service
        echo "Password auth disabled."
      fi
    fi
  fi
fi

section "Setup complete!"
