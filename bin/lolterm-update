#!/usr/bin/env bash
set -euo pipefail

ASSUME_YES=false

usage() {
  cat <<'USAGE'
Usage: lolterm-update [options]

Options:
  -y, --yes   Run DNF upgrade non-interactively
  --help      Show this help
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -y|--yes) ASSUME_YES=true; shift ;;
    --help) usage; exit 0 ;;
    *) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

update_dnf_packages() {
  echo "Updating Fedora DNF packages..."
  if $ASSUME_YES; then
    sudo dnf upgrade -y
  else
    sudo dnf upgrade
  fi
}

update_kali_container() {
  if podman container exists kali &>/dev/null; then
    echo "Updating Kali container packages..."
    if podman ps --filter name=kali --filter status=running --format '{{.Names}}' | grep -qxF kali; then
      podman exec kali apt-get update
      podman exec kali apt-get upgrade -y
      podman exec kali apt-get autoremove -y
      podman exec kali apt-get clean
      echo "Kali container packages updated."
    else
      echo "Kali container exists but is not running. Skipping container update."
      echo "Start it with: podman start kali"
    fi
  fi
}

update_rtk() {
  echo "Updating rtk..."
  arch="$(uname -m)"
  tmpdir="$(mktemp -d)"

  if [[ "$arch" != "x86_64" ]]; then
    echo "rtk release RPM updates are currently supported only on x86_64." >&2
    echo "Skipping rtk because no verified Fedora RPM path is defined for $arch." >&2
    rm -rf "$tmpdir"
    return 0
  fi

  release_json="$(curl -fsSL https://api.github.com/repos/rtk-ai/rtk/releases/latest)"
  version="$(jq -r '.tag_name | sub("^v"; "")' <<<"$release_json")"
  rpm_name="rtk-${version}-1.x86_64.rpm"
  download_base="https://github.com/rtk-ai/rtk/releases/download/v${version}"

  curl -fsSLo "$tmpdir/$rpm_name" "$download_base/$rpm_name"
  curl -fsSLo "$tmpdir/checksums.txt" "$download_base/checksums.txt"
  (cd "$tmpdir" && grep -E "[[:space:]]+$rpm_name$" checksums.txt | sha256sum -c -)
  sudo dnf install -y "$tmpdir/$rpm_name"
  rm -rf "$tmpdir"
}

update_dnf_packages
update_rtk
update_kali_container

echo "Fedora packages and lolterm-managed non-DNF tools updated."
