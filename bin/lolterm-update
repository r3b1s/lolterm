#!/usr/bin/env bash
set -euo pipefail

ASSUME_YES=false

usage() {
  cat <<'USAGE'
Usage: lolterm-update [options]

Options:
  -y, --yes   Run DNF upgrade non-interactively
  --help      Show this help
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -y|--yes) ASSUME_YES=true; shift ;;
    --help) usage; exit 0 ;;
    *) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

update_dnf_packages() {
  echo "Updating Fedora DNF packages..."
  if $ASSUME_YES; then
    sudo dnf upgrade -y
  else
    sudo dnf upgrade
  fi
}

update_kali_container() {
  if podman container exists kali &>/dev/null; then
    echo "Updating Kali container packages..."
    if podman ps --filter name=kali --filter status=running --format '{{.Names}}' | grep -qxF kali; then
      podman exec kali apt-get update
      podman exec kali apt-get upgrade -y
      podman exec kali apt-get autoremove -y
      podman exec kali apt-get clean
      echo "Kali container packages updated."
    else
      echo "Kali container exists but is not running. Skipping container update."
      echo "Start it with: podman start kali"
    fi
  fi
}

update_lazydocker() {
  if ! command -v lazydocker &>/dev/null; then
    return 0
  fi
  echo "Updating lazydocker..."

  local arch tmpdir
  arch="$(uname -m)"
  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' RETURN

  local release_json version tarball_name download_base
  release_json="$(curl -fsSL https://api.github.com/repos/jesseduffield/lazydocker/releases/latest)"
  version="$(jq -r '.tag_name | sub("^v"; "")' <<<"$release_json")"

  case "$arch" in
    x86_64)  arch="x86_64" ;;
    aarch64) arch="arm64" ;;
    *) echo "Unsupported architecture for lazydocker: $arch" >&2; return 1 ;;
  esac

  tarball_name="lazydocker_${version}_Linux_${arch}.tar.gz"
  download_base="https://github.com/jesseduffield/lazydocker/releases/download/v${version}"

  curl -fsSLo "$tmpdir/$tarball_name" "$download_base/$tarball_name"
  curl -fsSLo "$tmpdir/checksums.txt" "$download_base/checksums.txt"
  (cd "$tmpdir" && grep -E "[[:space:]]+$tarball_name$" checksums.txt | sha256sum -c -)
  tar -xzf "$tmpdir/$tarball_name" -C "$tmpdir"
  sudo install -m 755 "$tmpdir/lazydocker" /usr/local/bin/lazydocker
  echo "lazydocker updated to v${version}"
}

update_rtk() {
  echo "Updating rtk..."

  local arch rpm_name release_json version download_base tmpdir
  arch="$(uname -m)"

  if [[ "$arch" != "x86_64" ]]; then
    echo "rtk release RPM updates are currently supported only on x86_64." >&2
    echo "Skipping rtk because no verified Fedora RPM path is defined for $arch." >&2
    return 0
  fi

  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' RETURN

  release_json="$(curl -fsSL https://api.github.com/repos/rtk-ai/rtk/releases/latest)"
  version="$(jq -r '.tag_name | sub("^v"; "")' <<<"$release_json")"
  rpm_name="rtk-${version}-1.x86_64.rpm"
  download_base="https://github.com/rtk-ai/rtk/releases/download/v${version}"

  curl -fsSLo "$tmpdir/$rpm_name" "$download_base/$rpm_name"
  curl -fsSLo "$tmpdir/checksums.txt" "$download_base/checksums.txt"
  (cd "$tmpdir" && grep -E "[[:space:]]+$rpm_name$" checksums.txt | sha256sum -c -)
  sudo dnf install -y "$tmpdir/$rpm_name"
}

update_colgrep() {
  if ! command -v colgrep &>/dev/null; then
    return 0
  fi
  echo "Updating colgrep..."

  local arch tarball_name tmpdir
  arch="$(uname -m)"

  if [[ "$arch" != "x86_64" ]]; then
    echo "colgrep updates are currently supported only on x86_64." >&2
    echo "Skipping colgrep because no verified release artifact is available for $arch." >&2
    return 0
  fi

  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' RETURN

  local release_json version download_base
  release_json="$(curl -fsSL https://api.github.com/repos/lightonai/next-plaid/releases/latest)"
  version="$(jq -r '.tag_name | sub("^v"; "")' <<<"$release_json")"
  tarball_name="colgrep-x86_64-unknown-linux-gnu.tar.xz"
  download_base="https://github.com/lightonai/next-plaid/releases/download/v${version}"

  curl -fsSLo "$tmpdir/$tarball_name" "$download_base/$tarball_name"
  curl -fsSLo "$tmpdir/$tarball_name.sha256" "$download_base/$tarball_name.sha256"
  (cd "$tmpdir" && sha256sum -c "$tarball_name.sha256")
  tar -xJf "$tmpdir/$tarball_name" -C "$tmpdir" --strip-components=1
  if [[ ! -f "$tmpdir/colgrep" ]]; then
    echo "WARNING: colgrep binary not found in tarball; archive structure may have changed. Skipping." >&2
    return 0
  fi
  install -m 755 "$tmpdir/colgrep" "$HOME/.local/bin/colgrep"
  echo "colgrep updated to v${version}"
}

update_dnf_packages
update_lazydocker
update_rtk
update_colgrep
update_kali_container

echo "Fedora packages and lolterm-managed non-DNF tools updated."
